# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Your deployed backend URL (no trailing slash)
# Used for: API base, webhook callbacks, and WhatsApp template button redirects
#
# ── WhatsApp template registration ──────────────────────────────────────────
# Register your templates in Meta/WhatsApp Business Manager with these base URLs.
# The /go/ routes redirect guests to FRONTEND_URL, so you can change the frontend
# domain any time in .env without re-registering or re-approving the template.
#
#   RSVP button  base URL → {APP_URL}/go/rsvp/
#   QR button    base URL → {APP_URL}/go/qr/
#   Accept link  base URL → {APP_URL}/go/accept/
#
# Example (production): APP_URL=https://api.myapp.com
#   Register template with: https://api.myapp.com/go/rsvp/
#   Guest taps button  → https://api.myapp.com/go/rsvp/guest-uuid
#   Backend redirects  → https://myfrontend.vercel.app/rsvp/guest-uuid  (FRONTEND_URL)
# ────────────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3000

# Your deployed frontend URL (no trailing slash)
# Change this any time — all WhatsApp button links will automatically follow.
# ⚠️  Must be a live public URL for WhatsApp messages to work in production.
#
# Required frontend routes:
#   /rsvp/:guestId    → RSVP page    (calls POST /api/v1/rsvp/respond)
#   /qr/:qrCode       → QR display page
#   /accept/:qrCode   → Accept page  (calls POST /api/v1/rsvp/accept)
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/eventflow?schema=public"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EventFlow <noreply@eventflow.app>

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp (GhalaRails)
GHALA_RAILS_API_URL=https://api.ghala.io
GHALA_RAILS_JWT=
GHALA_RAILS_CREDENTIAL_ID=
GHALA_RAILS_WEBHOOK_VERIFY_TOKEN=
GHALARAILS_API_KEY=

# SMS (Briq)
BRIQ_SMS_BASE_URL=https://karibu.briq.tz
BRIQ_SMS_SEND_PATH=/v1/message/send-instant
BRIQ_SMS_API_KEY=
BRIQ_SMS_SENDER_ID=BRIQ
BRIQ_SMS_AUTH_HEADER=X-API-Key
BRIQ_SMS_AUTH_SCHEME=
BRIQ_API_KEY=

# Sarufi
SARUFI_BASE_URL=
SARUFI_AGENT_ID=
SARUFI_WORKSPACE_ID=
SARUFI_OAUTH_CLIENT_ID=
SARUFI_OAUTH_CLIENT_SECRET=
SARUFI_ACCESS_TOKEN=
SARUFI_REFRESH_TOKEN=
SARUFI_WEBHOOK_SECRET=

# EventFlow MCP / internal tool security
MCP_SERVER_URL=
MCP_AUTH_MODE=bearer
MCP_BEARER_TOKEN=

# Snippe
SNIPPE_BASE_URL=
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_SECRET=

# OAuth (ready)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Security
CSRF_SECRET=csrf-secret-min-32-chars-long!!!!!!
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Subscription / Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
